{
  "compilerOptions": {
    "target": "es5",
    "module": "commonJS",
    "lib": ["dom", "dom.iterable", "esnext"],
    "types": ["jest", "node"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "build"]
}
